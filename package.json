{
  "name": "escala-verbo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:cf": "npx @cloudflare/next-on-pages && wrangler pages dev",
    "build": "next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "pages:build": "npx @cloudflare/next-on-pages",
    "pages:deploy": "wrangler pages deploy",
    "db:migrate:local": "wrangler d1 execute escala-verbo-db --local --file=prisma/migrations/0001_init.sql",
    "db:migrate:prod": "wrangler d1 execute escala-verbo-db --file=prisma/migrations/0001_init.sql"
  },
  "dependencies": {
    "next": "14.1.0",
    "@cloudflare/next-on-pages": "^1.13.12",
    "@prisma/adapter-d1": "^5.22.0",
    "@prisma/client": "^5.22.0",
    "react": "^18",
    "react-dom": "^18",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240512.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "postcss": "^8",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.3.0",
    "typescript": "^5",
    "wrangler": "^3.0.0"
  }
}
